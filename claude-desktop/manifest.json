{
  "manifest_version": "0.3",
  "name": "paper",
  "version": "0.1.9",
  "description": "Paper connects your teams, agents, code, and data on a single design space built on web standards, so nothing gets lost in translation.",
  "author": {
    "name": "Paper"
  },
  "icon": "./assets/logo@128w.png",
  "homepage": "https://paper.design",
  "documentation": "https://paper.design/docs/mcp",
  "server": {
    "type": "node",
    "entry_point": "./src/index.js",
    "mcp_config": {
      "command": "npx",
      "args": ["mcp-remote", "http://127.0.0.1:29979/mcp"]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paper-design/agent-plugins.git"
  },
  "keywords": ["paper", "design", "collaboration"]
}
